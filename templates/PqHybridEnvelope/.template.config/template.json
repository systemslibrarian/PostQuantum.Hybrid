{
  "$schema": "http://json.schemastore.org/template",
  "author": "Paul Clark",
  "classifications": [ "Common", "Console", "Cryptography", "Post-Quantum" ],
  "name": "PostQuantum.Hybrid envelope CLI",
  "description": "A console app that seals and opens files using PostQuantum.Hybrid.Envelopes. Drop-in starter for at-rest hybrid post-quantum encryption.",
  "identity": "PostQuantum.Hybrid.Templates.PqHybridEnvelope",
  "shortName": "pqhybrid-envelope",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "PqHybridEnvelopeTemplate",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "Target framework.",
      "datatype": "choice",
      "choices": [
        { "choice": "net10.0", "description": "Target net10.0 (native ML-KEM)" },
        { "choice": "net8.0",  "description": "Target net8.0 (BouncyCastle backend)" }
      ],
      "defaultValue": "net10.0",
      "replaces": "PqHybridEnvelopeTemplateFramework"
    },
    "PackageVersion": {
      "type": "parameter",
      "description": "PostQuantum.Hybrid version.",
      "datatype": "string",
      "defaultValue": "1.0.0",
      "replaces": "PqHybridEnvelopeTemplatePackageVersion"
    }
  }
}

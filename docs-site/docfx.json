{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",

  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/PostQuantum.Hybrid/PostQuantum.Hybrid.csproj",
            "src/PostQuantum.Hybrid.Envelopes/PostQuantum.Hybrid.Envelopes.csproj",
            "src/PostQuantum.Hybrid.AspNetCore/PostQuantum.Hybrid.AspNetCore.csproj",
            "src/PostQuantum.Hybrid.TestingSupport/PostQuantum.Hybrid.TestingSupport.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "memberLayout": "samePage",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],

  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      },
      {
        "src": "..",
        "files": [
          "docs/**/*.md",
          "docs/**/*.yml",
          "samples/README.md",
          "KNOWN-GAPS.md",
          "HARDENING-CHECKLIST.md",
          "CHANGELOG.md",
          "SECURITY.md",
          "CONTRIBUTING.md"
        ],
        "dest": "."
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "PostQuantum.Hybrid",
      "_appTitle": "PostQuantum.Hybrid — Hybrid Post-Quantum Cryptography for .NET",
      "_appFooter": "PostQuantum.Hybrid — MIT licensed. Built in gratitude to God. 1 Corinthians 10:31.",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/systemslibrarian/PostQuantum.Hybrid",
        "branch": "main"
      },
      "pdf": false
    },
    "sitemap": {
      "baseUrl": "https://systemslibrarian.github.io/PostQuantum.Hybrid",
      "changefreq": "weekly",
      "priority": 0.5
    },
    "xref": [
      "https://learn.microsoft.com/en-us/dotnet/.xrefmap.json"
    ]
  }
}

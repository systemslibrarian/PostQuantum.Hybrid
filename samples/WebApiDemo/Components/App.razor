@*
    Root document for the Blazor Server playground. Single-page UI with
    anchor-link navigation — there is only one "page" (Home.razor); the
    Router still gates on @page directives so future expansion remains
    cheap.
*@

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>PostQuantum.Hybrid — interactive demo</title>
    <meta name="description" content="Gold-standard reference implementation for the PostQuantum.Hybrid .NET library. Hybrid KEM (X25519 + ML-KEM-768) and hybrid signatures (Ed25519 + ML-DSA-65) demonstrated end-to-end in your browser." />
    <link rel="stylesheet" href="app.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Copy-to-clipboard for <CopyableCode> components. Independent of
        // Blazor render-mode wiring — works on the static and interactive
        // sections alike.
        function copyFromSnippet(btn) {
            const snippet = btn.closest('.snippet');
            if (!snippet) return;
            const codeEl = snippet.querySelector('code');
            if (!codeEl) return;
            const text = codeEl.textContent || '';
            const restore = () => {
                btn.textContent = 'Copy';
                btn.classList.remove('copy-btn-done');
            };
            const flash = () => {
                btn.textContent = 'Copied';
                btn.classList.add('copy-btn-done');
                setTimeout(restore, 1400);
            };
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(flash).catch(() => {
                    btn.textContent = 'Copy failed';
                    setTimeout(restore, 1400);
                });
            } else {
                // Fallback for older browsers.
                const ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); flash(); }
                catch { btn.textContent = 'Copy failed'; setTimeout(restore, 1400); }
                document.body.removeChild(ta);
            }
        }
    </script>
</body>

</html>
